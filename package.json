{
  "name": "course-pipeline",
  "version": "1.0.0",
  "description": "TechNuggets Academy — multi-chapter course creation pipeline",
  "type": "commonjs",
  "scripts": {
    "start": "python3 -m http.server 8080",
    "render:1": "node render/course-render.js 1",
    "render:2": "node render/course-render.js 2",
    "render:3": "node render/course-render.js 3",
    "render:4": "node render/course-render.js 4",
    "render:5": "node render/course-render.js 5",
    "render:6": "node render/course-render.js 6",
    "render:7": "node render/course-render.js 7",
    "render:8": "node render/course-render.js 8",
    "render:9": "node render/course-render.js 9",
    "render:1:force": "node render/course-render.js 1 --force",
    "render:2:force": "node render/course-render.js 2 --force",
    "render:3:force": "node render/course-render.js 3 --force",
    "render:4:force": "node render/course-render.js 4 --force",
    "render:5:force": "node render/course-render.js 5 --force",
    "render:6:force": "node render/course-render.js 6 --force",
    "render:7:force": "node render/course-render.js 7 --force",
    "render:8:force": "node render/course-render.js 8 --force",
    "render:9:force": "node render/course-render.js 9 --force",
    "render:all": "node render/course-render-all.js",
    "render:all:force": "node render/course-render-all.js --force",
    "test": "node tests/test-runner.js",
    "test:watch": "node --watch --test tests/e2e.test.js",
    "test:verbose": "node --test --test-reporter=spec tests/e2e.test.js",
    "predeploy": "bash scripts/pre-deploy-check.sh",
    "promo": "node render/promo-render.js",
    "promo:preview": "node render/promo-render.js --preview",
    "promo:no-vertical": "node render/promo-render.js --no-vertical",
    "archive": "node archive.js",
    "archive:list": "ls -la exports/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aseemmankotia/course-pipeline.git"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.14.0",
    "node-fetch": "^2.7.0",
    "puppeteer": "^24.40.0"
  }
}
