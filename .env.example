# ── Anthropic API (primary) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google Gemini API (fallback — free tier available) ────────────────────────
# Used automatically when Anthropic returns a credit/balance error.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-your-gemini-key-here

# ── YouTube Data API v3 (for publishing) ──────────────────────────────────────
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# ── HeyGen avatar videos ──────────────────────────────────────────────────────
# No env var needed — export videos from HeyGen as heygen-chapter-NN.mp4 and
# place in one of:
#   render/chapters/chapter-NN/heygen-chapter-NN.mp4   (preferred)
#   ~/Downloads/heygen-chapter-NN.mp4                  (auto-detected fallback)
