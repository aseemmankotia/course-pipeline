# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── ElevenLabs TTS (voice narration) ─────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-cloned-voice-id
# Models:
#   eleven_monolingual_v1  — English only, fastest, cheapest (~$0.30/1k chars)
#   eleven_multilingual_v2 — 70 languages, best quality (~$0.30/1k chars)
#   eleven_turbo_v2        — fast, good quality, balanced cost
ELEVENLABS_MODEL=eleven_monolingual_v1

# ── Presenter photo (PIP overlay) ─────────────────────────────────────────────
# Place a JPG headshot in the project root.
# Recommended: 400x400px or larger, square crop, good lighting, looking at camera.
# If omitted, video renders without the PIP overlay.
PRESENTER_PHOTO=presenter.jpg

# ── YouTube Data API v3 (for publishing) ──────────────────────────────────────
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
